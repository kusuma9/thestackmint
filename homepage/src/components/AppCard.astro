---
import type { Tool } from '../tools.config';

interface Props {
  tool: Tool;
  accentColor?: 'mint' | 'cyan';
}

const { tool, accentColor = 'cyan' } = Astro.props;
const glow = accentColor === 'mint'
  ? 'hover:shadow-[0_4px_32px_rgba(0,229,160,0.12)] hover:border-mint/40'
  : 'hover:shadow-[0_4px_32px_rgba(0,196,255,0.12)] hover:border-cyan/40';
const btnClass = accentColor === 'mint'
  ? 'bg-mint/10 text-mint hover:bg-mint hover:text-bg'
  : 'bg-cyan/10 text-cyan hover:bg-cyan hover:text-bg';
---

<div
  class:list={[
    'group flex flex-col gap-3 p-5 rounded-xl border border-border bg-surface',
    'transition-all duration-200 hover:-translate-y-0.5',
    glow,
  ]}
>
  <!-- Icon + admin badge -->
  <div class="flex items-start justify-between">
    <span class="text-3xl leading-none" aria-hidden="true">{tool.icon}</span>
    {tool.adminOnly && (
      <span class="text-[9px] font-mono uppercase tracking-widest text-muted/60 bg-surface2
                   border border-border/50 px-1.5 py-0.5 rounded-full">
        admin
      </span>
    )}
  </div>

  <!-- Name + description -->
  <div class="flex flex-col gap-1 flex-1">
    <span class="font-semibold text-white text-sm leading-snug">
      {tool.name}
    </span>
    <span class="text-muted text-xs leading-relaxed line-clamp-2">
      {tool.description}
    </span>
  </div>

  <!-- Open button -->
  <a
    href={tool.url}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      'mt-auto inline-flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg',
      'text-xs font-semibold transition-all duration-150',
      'focus-visible:outline-2 focus-visible:outline-offset-2',
      btnClass,
    ]}
  >
    Open
    <svg class="w-3 h-3 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
    </svg>
  </a>
</div>
