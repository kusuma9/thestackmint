# Hermes Agent + WebUI — copy to .env and fill in values

# WebUI settings (do not change these)
WANTED_UID=1000
WANTED_GID=1000
HERMES_WEBUI_HOST=0.0.0.0
HERMES_WEBUI_STATE_DIR=/home/hermeswebui/.hermes/webui

# Optional: extra password on top of Authelia (recommended for defence-in-depth)
# HERMES_WEBUI_PASSWORD=change-me-to-something-strong

# LLM provider — uncomment ONE and fill in your key:
#ANTHROPIC_API_KEY=sk-ant-...
#OPENAI_API_KEY=sk-...
#OPENROUTER_API_KEY=sk-or-...

# Optional integrations
#TELEGRAM_BOT_TOKEN=
#TELEGRAM_ALLOWED_USERS=
