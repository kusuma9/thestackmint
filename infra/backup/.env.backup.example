# Restic Backup Configuration
# Copy to: /root/.env.backup  (root-only permissions: chmod 600 /root/.env.backup)

# Hetzner Object Storage (S3-compatible)
# Format: s3:https://<region>.your-objectstorage.com/<bucket-name>
# Hetzner endpoint example: s3:https://fsn1.your-objectstorage.com/mystackmint-backup
RESTIC_REPOSITORY=s3:https://fsn1.your-objectstorage.com/your-bucket-name

# Encryption passphrase — keep a copy offline, losing this means losing all backups
RESTIC_PASSWORD=your_very_strong_backup_encryption_passphrase

# Hetzner Object Storage credentials
# Create at: Hetzner Cloud Console → Object Storage → Access Keys
AWS_ACCESS_KEY_ID=your_hetzner_object_storage_access_key
AWS_SECRET_ACCESS_KEY=your_hetzner_object_storage_secret_key

# Ntfy push notifications (self-hosted — deploy infra/ntfy/ first)
NTFY_URL=https://ntfy.mystackmint.com
NTFY_TOPIC=backup-alerts
