# Cloudflare API Token
# Create at: Cloudflare Dashboard → My Profile → API Tokens
# Required permissions: Zone → DNS → Edit (for your zone only)
CF_DNS_API_TOKEN=your_cloudflare_dns_api_token_here

# Traefik dashboard basic auth
# Generate the hash with:
#   htpasswd -nb admin 'your_password'
# OR (Docker, no htpasswd installed):
#   docker run --rm httpd:2.4-alpine htpasswd -nb admin 'your_password'
# Double $ signs in docker-compose: replace each $ with $$
TRAEFIK_DASHBOARD_USERS=admin:$$apr1$$replace$$with$$real$$hash$$here

# CrowdSec bouncer API key
# Deploy infra/crowdsec/ first — the key is pre-registered via BOUNCER_KEY_traefik env var
# Copy the same value you set in infra/crowdsec/.env
CROWDSEC_BOUNCER_API_KEY=your_crowdsec_bouncer_api_key_here
