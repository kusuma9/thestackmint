# Hermes Workspace — copy to .env and fill in values

# Required: shared auth token between agent gateway and workspace
# Generate: openssl rand -hex 32
API_SERVER_KEY=change-me-64-char-hex

# Required: UI login password (on top of Authelia SSO)
# Generate: openssl rand -base64 24
HERMES_PASSWORD=change-me-strong-password

# LLM provider — OpenRouter gives access to 200+ models
OPENROUTER_API_KEY=sk-or-...
