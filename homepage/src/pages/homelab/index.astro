---
import DashLayout from '../../layouts/DashLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import Sidebar from '../../components/Sidebar.astro';
import SearchModal from '../../components/SearchModal.astro';
import { tools, HOMELAB_CATEGORIES } from '../../tools.config';

const homelabTools = tools.filter((t) => t.section === 'homelab');
const totalTools = homelabTools.length;
---

<DashLayout title="Personal HomeLab — MyStackMint">

  <Sidebar categories={HOMELAB_CATEGORIES} withNavbar />
  <SearchModal />

  <!-- Main content — offset for sidebar on large screens -->
  <div class="lg:ml-56 min-h-[calc(100vh-3.5rem)] flex flex-col">

    <!-- Top bar -->
    <div class="sticky top-14 z-10 bg-bg/95 backdrop-blur border-b border-border">
      <div class="flex items-center gap-3 px-4 lg:px-8 h-12">

        <!-- Mobile menu toggle -->
        <button
          id="menu-toggle"
          class="lg:hidden text-muted hover:text-white transition-colors p-1 rounded
                 focus-visible:outline-mint focus-visible:outline-2"
          aria-label="Open menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

        <!-- Search trigger -->
        <button
          id="search-btn"
          class="flex-1 flex items-center gap-2 bg-surface border border-border rounded-lg
                 px-3 py-1.5 text-sm text-muted hover:border-mint/40 hover:text-white transition-all
                 focus-visible:outline-mint focus-visible:outline-2 max-w-sm"
          aria-label="Search tools (Ctrl+K)"
        >
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <span class="flex-1 text-left text-xs">Search tools...</span>
          <kbd class="hidden sm:block text-[10px] font-mono bg-surface2 border border-border px-1.5 py-0.5 rounded">
            ⌘K
          </kbd>
        </button>

        <span class="hidden sm:block ml-auto text-xs font-mono text-muted">
          {totalTools} tools
        </span>
      </div>
    </div>

    <!-- Page body -->
    <main class="flex-1 px-4 lg:px-8 py-8">

      <!-- Breadcrumb + heading -->
      <div class="mb-8">
        <nav class="text-xs font-mono text-muted mb-2">
          <a href="/dashboard" class="hover:text-mint transition-colors">Dashboard</a>
          <span class="mx-1.5 opacity-40">/</span>
          <span class="text-white">Personal HomeLab</span>
        </nav>
        <h2 class="text-2xl font-bold text-white">
          🏠 Personal <span class="text-mint">HomeLab</span>
        </h2>
        <p class="text-sm text-muted mt-1">
          {totalTools} family tools — all self-hosted, all private.
        </p>
      </div>

      <!-- Active category heading -->
      <div class="flex items-center justify-between mb-4">
        <h3 id="active-category-label" class="text-xs font-mono text-muted uppercase tracking-widest">
          All Tools
        </h3>
        <span id="visible-count" class="text-xs font-mono text-muted/60">
          {totalTools} tools
        </span>
      </div>

      <!-- Tool grid -->
      <div
        id="tool-grid"
        class="grid gap-3 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5"
      >
        {homelabTools.map((tool) => (
          <div class="tool-card-wrapper" data-category={tool.category} data-tool-id={tool.id}>
            <ToolCard tool={tool} />
          </div>
        ))}
      </div>

      <!-- No results -->
      <div id="no-results" class="hidden py-16 text-center">
        <p class="text-4xl mb-3">🔍</p>
        <p class="text-muted text-sm">No tools in this category</p>
      </div>

    </main>
  </div>

  <script>
    import { setupSearch } from '../../scripts/search';
    import { setupStatus } from '../../scripts/status';

    // Sidebar category filtering
    function filterCategory(category: string) {
      const wrappers = document.querySelectorAll<HTMLElement>('.tool-card-wrapper');
      let visible = 0;

      wrappers.forEach((w) => {
        const show = category === 'all' || w.dataset.category === category;
        w.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      document.getElementById('visible-count')!.textContent = `${visible} tool${visible !== 1 ? 's' : ''}`;
      document.getElementById('active-category-label')!.textContent =
        category === 'all' ? 'All Tools' : category;
      document.getElementById('no-results')!.classList.toggle('hidden', visible > 0);

      document.querySelectorAll<HTMLButtonElement>('.sidebar-btn').forEach((btn) => {
        const active = btn.dataset.category === category;
        btn.classList.toggle('active', active);
        btn.classList.toggle('text-white', active);
        btn.classList.toggle('bg-mint/10', active);
        btn.classList.toggle('border-mint', active);
        btn.classList.toggle('text-muted', !active);
        btn.classList.toggle('border-transparent', !active);
        btn.setAttribute('aria-pressed', String(active));
      });
    }

    document.querySelectorAll<HTMLButtonElement>('.sidebar-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        filterCategory(btn.dataset.category ?? 'all');
        document.getElementById('sidebar')?.classList.add('-translate-x-full');
        document.getElementById('sidebar-overlay')?.classList.add('hidden');
      });
    });

    document.getElementById('menu-toggle')?.addEventListener('click', () => {
      document.getElementById('sidebar')?.classList.toggle('-translate-x-full');
      document.getElementById('sidebar-overlay')?.classList.toggle('hidden');
    });

    setupSearch();
    setupStatus();
  </script>

</DashLayout>
