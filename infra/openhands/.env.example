# Default LLM model and API key
# Model can be switched per-session in the OpenHands web UI settings
LLM_MODEL=anthropic/claude-sonnet-4-6
LLM_API_KEY=your-anthropic-api-key-here

# To use OpenRouter instead:
#   LLM_MODEL=openrouter/anthropic/claude-sonnet-4-6
#   LLM_API_KEY=your-openrouter-api-key-here
# Any LiteLLM-compatible provider works — change both vars and restart.
