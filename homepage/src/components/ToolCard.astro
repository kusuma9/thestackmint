---
import type { Tool } from '../tools.config';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const isPath = tool.icon.startsWith('/') || tool.icon.startsWith('http');
---

<a
  href={tool.url}
  target="_blank"
  rel="noopener noreferrer"
  class="tool-card group flex flex-col gap-3 p-4 rounded-xl border border-border bg-surface
         transition-all duration-150 hover:border-mint/40 hover:bg-surface2
         focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-mint"
  data-tool-id={tool.id}
  data-tool-name={tool.name}
  data-tool-description={tool.description}
  data-tool-category={tool.category}
  data-tool-tags={tool.tags.join(',')}
>
  <!-- Top row: logo + controls -->
  <div class="flex items-start justify-between gap-2">

    <!-- Logo container — neutral, Coolify-style -->
    <div class="w-12 h-12 rounded-xl bg-surface2 border border-border flex items-center justify-center
                flex-shrink-0 transition-colors duration-150 group-hover:border-mint/20">
      {isPath ? (
        <>
          <img
            src={tool.icon}
            alt={tool.name}
            width="32"
            height="32"
            class="w-8 h-8 object-contain"
            loading="lazy"
            draggable="false"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
          />
          <span
            class="hidden w-8 h-8 items-center justify-center text-sm font-bold text-muted"
            aria-hidden="true"
          >
            {tool.name.charAt(0)}
          </span>
        </>
      ) : (
        <span class="text-2xl leading-none" aria-hidden="true">{tool.icon}</span>
      )}
    </div>

    <!-- Status dot + favorite -->
    <div class="flex items-center gap-1.5 pt-1">
      <span
        class="status-dot w-2 h-2 rounded-full bg-muted/30 transition-colors duration-500 flex-shrink-0"
        data-tool-id={tool.id}
        title="Checking status..."
      ></span>
      <button
        class="favorite-btn p-0.5 rounded text-muted/30 hover:text-amber-400 transition-colors duration-150
               focus-visible:outline-2 focus-visible:outline-mint"
        data-tool-id={tool.id}
        aria-label={`Favorite ${tool.name}`}
        onclick="event.preventDefault();event.stopPropagation();toggleFavorite(this);"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Name + description -->
  <div class="flex flex-col gap-1">
    <span class="font-semibold text-white text-sm leading-tight truncate">
      {tool.name}
    </span>
    <span class="text-muted text-xs leading-relaxed line-clamp-2">
      {tool.description}
    </span>
  </div>

  <!-- Category badge -->
  <div class="mt-auto">
    <span class="inline-block text-[10px] font-mono text-muted/60 bg-surface2 border border-border/50
                 px-2 py-0.5 rounded-full truncate max-w-full">
      {tool.category}
    </span>
  </div>
</a>
