---
interface Props {
  brand?: 'thestackmint' | 'familyhealth' | 'codefinderhub';
  backLink?: string;
}

const { brand = 'thestackmint', backLink } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="wrap nav">
    {brand === 'thestackmint' && (
      <a class="brand" href="/">
        <span class="brand-mark">T</span>
        <span class="brand-name">thestack<em>mint</em></span>
      </a>
    )}
    {brand === 'familyhealth' && (
      <a class="brand" href="/familyhealth">
        <span class="brand-mark">🌿</span>
        <span class="brand-name">Family <em>Healthcare</em></span>
      </a>
    )}
    {brand === 'codefinderhub' && (
      <a class="brand" href="/codefinderhub">
        <span class="brand-mark" style="background:#92400e">📮</span>
        <span class="brand-name">Code<em>FinderHub</em></span>
      </a>
    )}

    <button class="nav-toggle" aria-label="Menu" aria-expanded="false">☰</button>

    <ul class="nav-links">
      {backLink && (
        <li>
          <a href={backLink} style="font-size:0.82rem;color:#8d988f">← thestackmint</a>
        </li>
      )}
      {brand === 'thestackmint' && (
        <>
          <li><a href="#products" aria-current={currentPath === '/' ? 'page' : undefined}>Products</a></li>
          <li><a href="#about">About</a></li>
          <li><a href={`mailto:satish.technology9@gmail.com`}>Contact</a></li>
        </>
      )}
      {brand === 'familyhealth' && (
        <>
          <li><a href="#features">Features</a></li>
          <li><a href="#pricing">Pricing</a></li>
          <li><a href="#download">Download</a></li>
          <li><a href="#contact">Contact</a></li>
          <li><a class="btn btn-primary" href="#download">Get the app</a></li>
        </>
      )}
      {brand === 'codefinderhub' && (
        <>
          <li><a href="#tools">Tools</a></li>
          <li><a href="#why">Why us</a></li>
          <li><a href="https://codefinderhub.com" target="_blank" rel="noopener" class="btn btn-amber">Check it now →</a></li>
        </>
      )}
    </ul>
  </div>
</header>
