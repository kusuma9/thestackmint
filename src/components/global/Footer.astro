---
interface Props {
  brand?: 'thestackmint' | 'familyhealth' | 'codefinderhub';
}
const { brand = 'thestackmint' } = Astro.props;
---

<footer class="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        {brand === 'thestackmint' && (
          <>
            <a class="logo-stacked" href="/" style="margin-bottom:14px">
              <span class="lst-the">THE</span>
              <span class="lst-main">STACKMINT</span>
            </a>
            <p style="font-size:0.88rem;color:#8d988f;margin-top:10px;max-width:22rem">
              Solo-crafted apps for everyday life.
            </p>
          </>
        )}
        {brand === 'familyhealth' && (
          <>
            <a class="brand" href="/familyhealth" style="display:inline-flex;margin-bottom:14px">
              <span class="brand-mark">🌿</span>
              <span class="brand-name" style="color:#fff">Family <em>Healthcare</em></span>
            </a>
            <p style="font-size:0.88rem;color:#8d988f;margin-top:10px;max-width:22rem">
              Private family health management — a product of thestackmint.
            </p>
            <p style="margin-top:12px">
              <a href="/" style="color:#8d988f;font-size:0.84rem">← Back to thestackmint</a>
            </p>
          </>
        )}
        {brand === 'codefinderhub' && (
          <>
            <a class="brand" href="/codefinderhub" style="display:inline-flex;margin-bottom:14px">
              <span class="brand-mark" style="background:#92400e">📮</span>
              <span class="brand-name" style="color:#fff">Code<em>FinderHub</em></span>
            </a>
            <p style="font-size:0.88rem;color:#8d988f;margin-top:10px;max-width:22rem">
              India's free Pincode &amp; IFSC lookup tool — a product of thestackmint.
            </p>
            <p style="margin-top:12px">
              <a href="/" style="color:#8d988f;font-size:0.84rem">← Back to thestackmint</a>
            </p>
          </>
        )}
      </div>

      {brand === 'thestackmint' && (
        <>
          <div>
            <h4>Products</h4>
            <ul>
              <li><a href="/familyhealth">Family Healthcare</a></li>
              <li><a href="/codefinderhub">CodeFinderHub</a></li>
              <li style="color:#555f58;font-style:italic;font-size:0.9rem">More coming soon…</li>
            </ul>
          </div>
          <div>
            <h4>Legal</h4>
            <ul>
              <li><a href="/privacy">Privacy Policy</a></li>
              <li><a href="/terms">Terms of Service</a></li>
            </ul>
          </div>
          <div>
            <h4>Contact</h4>
            <ul>
              <li><a href="mailto:contact@thestackmint.com">contact@thestackmint.com</a></li>
            </ul>
          </div>
        </>
      )}

      {brand === 'familyhealth' && (
        <>
          <div>
            <h4>App</h4>
            <ul>
              <li><a href="#features">Features</a></li>
              <li><a href="#pricing">Pricing</a></li>
              <li><a href="#download">Download</a></li>
            </ul>
          </div>
          <div>
            <h4>Legal</h4>
            <ul>
              <li><a href="/privacy">Privacy Policy</a></li>
              <li><a href="/terms">Terms of Service</a></li>
            </ul>
          </div>
          <div>
            <h4>Support</h4>
            <ul>
              <li>Contact: <a href="mailto:familyhealth@thestackmint.com">familyhealth@thestackmint.com</a></li>
            </ul>
          </div>
        </>
      )}

      {brand === 'codefinderhub' && (
        <>
          <div>
            <h4>Tools</h4>
            <ul>
              <li><a href="https://codefinderhub.com/pincode?country=IN" target="_blank" rel="noopener">Pincode search</a></li>
              <li><a href="https://codefinderhub.com/ifsc?country=IN" target="_blank" rel="noopener">IFSC lookup</a></li>
              <li><a href="https://codefinderhub.com/branches?country=IN" target="_blank" rel="noopener">Bank branches</a></li>
            </ul>
          </div>
          <div>
            <h4>About</h4>
            <ul>
              <li><a href="#tools">Features</a></li>
              <li><a href="#why">Why us</a></li>
              <li><a href="https://codefinderhub.com" target="_blank" rel="noopener">Visit site</a></li>
            </ul>
          </div>
          <div>
            <h4>Contact</h4>
            <ul>
              <li><a href="mailto:contact@thestackmint.com">contact@thestackmint.com</a></li>
            </ul>
          </div>
        </>
      )}
    </div>

    <div class="footer-note">
      <span>© <span data-year></span> thestackmint. All rights reserved.</span>
      <div class="footer-author">
        Made with ♥ by <strong>Sathish Kusuma</strong>&nbsp;·&nbsp;Founder &amp; Developer
      </div>
    </div>
  </div>
</footer>
