# Enforce LF line endings for all shell scripts and config files (deployed to Linux)
* text=auto eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.md text eol=lf
*.ts text eol=lf
*.astro text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.css text eol=lf
