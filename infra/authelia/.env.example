# Authelia Secrets
# Generate secure random values with:
#   openssl rand -hex 32

# Used to sign password reset and identity verification JWTs
AUTHELIA_JWT_SECRET=replace_with_64_char_random_string

# Used to encrypt session cookies
AUTHELIA_SESSION_SECRET=replace_with_64_char_random_string

# Used to encrypt data at rest in the SQLite database
AUTHELIA_STORAGE_ENCRYPTION_KEY=replace_with_64_char_random_string

# SMTP notifier (optional — only needed if you replace the filesystem notifier)
# For Gmail: create an App Password at myaccount.google.com/apppasswords
# DO NOT set these if using the filesystem notifier — even an empty value
# activates SMTP and causes a config conflict.
#
# AUTHELIA_NOTIFIER_SMTP_HOST=smtp.gmail.com
# AUTHELIA_NOTIFIER_SMTP_PORT=587
# AUTHELIA_NOTIFIER_SMTP_USERNAME=you@gmail.com
# AUTHELIA_NOTIFIER_SMTP_PASSWORD=your-app-password
# AUTHELIA_NOTIFIER_SMTP_SENDER=Authelia <authelia@mystackmint.com>
