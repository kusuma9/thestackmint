# SaaS App: APP_NAME
# Copy to .env and fill all values before deploying

# App identity
APP_NAME=myapp
APP_DOMAIN=myapp.mystackmint.com

# Database
# Generate: openssl rand -base64 24
DB_PASSWORD=replace_with_strong_password

# Redis
# Generate: openssl rand -base64 24
REDIS_PASSWORD=replace_with_strong_password

# App secrets
# Generate: openssl rand -hex 32
SESSION_SECRET=replace_with_64_char_hex_string
JWT_SECRET=replace_with_64_char_hex_string

# Authelia protection (set to "true" to require login, "false" for public SaaS)
ENABLE_AUTH=false

# Email (optional — for transactional emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mystackmint.com

# Feature flags
NODE_ENV=production
LOG_LEVEL=info
