---
import type { Tool } from '../tools.config';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
---

<a
  href={tool.url}
  target="_blank"
  rel="noopener noreferrer"
  class="tool-card group relative flex flex-col gap-3 p-5 rounded-xl border border-border bg-surface
         transition-all duration-200 hover:border-mint/40 hover:bg-surface2 hover:-translate-y-0.5
         hover:shadow-[0_4px_24px_rgba(0,229,160,0.08)] focus-visible:outline-mint focus-visible:outline-2"
  data-tool-id={tool.id}
  data-tool-name={tool.name}
  data-tool-description={tool.description}
  data-tool-category={tool.category}
  data-tool-tags={tool.tags.join(',')}
>
  <!-- Favorite button -->
  <button
    class="favorite-btn absolute top-3 right-3 text-muted/40 hover:text-amber-400 transition-colors
           focus-visible:outline-mint focus-visible:outline-2 rounded"
    data-tool-id={tool.id}
    aria-label={`Favorite ${tool.name}`}
    title="Add to favorites"
    onclick="event.preventDefault(); event.stopPropagation(); toggleFavorite(this);"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
    </svg>
  </button>

  <!-- Icon + status -->
  <div class="flex items-start justify-between">
    <span class="text-3xl leading-none" aria-hidden="true">{tool.icon}</span>
    <span
      class="status-dot w-2.5 h-2.5 rounded-full bg-muted/30 mt-1 transition-colors duration-500"
      data-tool-id={tool.id}
      title="Checking status..."
    ></span>
  </div>

  <!-- Name + description -->
  <div class="flex flex-col gap-1 pr-4">
    <span class="font-semibold text-white text-sm leading-snug group-hover:text-mint transition-colors">
      {tool.name}
    </span>
    <span class="text-muted text-xs leading-relaxed line-clamp-2">
      {tool.description}
    </span>
  </div>

  <!-- Category tag -->
  <div class="mt-auto">
    <span class="inline-block text-[10px] font-mono text-muted/60 bg-surface2 border border-border/50
                 px-2 py-0.5 rounded-full truncate max-w-full">
      {tool.category}
    </span>
  </div>
</a>
