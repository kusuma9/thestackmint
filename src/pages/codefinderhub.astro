---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';

const title = "CodeFinderHub — India's Pincode & IFSC Lookup";
const description = "Instant Indian postal and banking code lookups. Find Pincode details, IFSC codes, bank branches and post offices in milliseconds — free web UI and REST API.";
const canonicalUrl = 'https://thestackmint.com/codefinderhub';
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage="/og-codefinderhub.png"
>
  <Header brand="codefinderhub" backLink="/" />

  <main>

    <!-- ── Hero ── -->
    <section class="hero" style="padding-bottom:80px">
      <div class="wrap hero-grid">
        <div>
          <span class="eyebrow reveal in" style="background:var(--amber-soft);color:var(--amber)">
            Built for India's developers &amp; businesses
          </span>
          <h1 class="reveal in d1" style="color:var(--ink)">
            Find any Pincode or IFSC in <span class="accent" style="color:var(--amber);font-style:italic">milliseconds.</span>
          </h1>
          <p class="lede reveal in d2">
            India has 19,000+ IFSC codes and 30,000+ Pincodes. CodeFinderHub lets your app — or your team — look them all up instantly.
            Clean REST API. Batch processing. Dead-simple web UI. Always free to start.
          </p>
          <div class="hero-ctas reveal in d3">
            <a class="btn btn-amber" href="https://codefinderhub.com" target="_blank" rel="noopener">Try it free →</a>
            <a class="btn btn-ghost" style="border-color:var(--amber);color:var(--amber)" href="#features">See what it does</a>
          </div>
        </div>
        <div class="reveal in d2" style="display:flex;align-items:center;justify-content:center">
          <div style="background:linear-gradient(145deg,#92400e,#78350f);border-radius:28px;padding:28px;box-shadow:0 40px 80px rgba(120,53,15,0.35)">
            <div style="background:var(--cream);border-radius:18px;padding:20px;min-width:260px">
              <div style="font-family:var(--font-display);font-weight:700;font-size:0.95rem;margin-bottom:14px;color:var(--ink)">
                🔍 Try a lookup
              </div>
              <div style="background:#fff;border:1.5px solid var(--amber);border-radius:10px;padding:12px 14px;font-size:0.9rem;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center">
                <span style="color:var(--ink-soft)">600001</span>
                <span style="background:var(--amber);color:#fff;border-radius:6px;padding:3px 10px;font-size:0.72rem;font-weight:700">FOUND</span>
              </div>
              <div style="background:#fff;border:1px solid var(--line);border-radius:10px;padding:14px;font-size:0.85rem;margin-bottom:8px">
                <div style="font-weight:700;font-family:var(--font-display);margin-bottom:6px">📍 Chennai GPO</div>
                <div style="color:var(--ink-soft);font-size:0.8rem">Tamil Nadu · Chennai District</div>
                <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap">
                  <span style="background:var(--amber-soft);color:var(--amber);font-size:0.7rem;font-weight:700;padding:2px 8px;border-radius:5px">PINCODE</span>
                  <span style="background:var(--green-soft);color:var(--green);font-size:0.7rem;font-weight:700;padding:2px 8px;border-radius:5px">7 Post Offices</span>
                </div>
              </div>
              <div style="background:#fff;border:1px solid var(--line);border-radius:10px;padding:14px;font-size:0.85rem">
                <div style="font-weight:700;font-family:var(--font-display);margin-bottom:6px">🏦 SBIN0000300</div>
                <div style="color:var(--ink-soft);font-size:0.8rem">State Bank of India · Fort Branch</div>
                <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap">
                  <span style="background:var(--amber-soft);color:var(--amber);font-size:0.7rem;font-weight:700;padding:2px 8px;border-radius:5px">IFSC</span>
                  <span style="background:var(--green-soft);color:var(--green);font-size:0.7rem;font-weight:700;padding:2px 8px;border-radius:5px">NEFT · RTGS</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Features ── -->
    <section id="features" class="section-alt">
      <div class="wrap">
        <p class="kicker reveal" style="color:var(--amber)">Everything included</p>
        <h2 class="reveal">One tool. Every code.<br>All of India.</h2>
        <p class="section-intro reveal">
          Whether you're a developer integrating address validation, a fintech verifying bank details,
          or an ops team looking up branches — CodeFinderHub has you covered.
        </p>
        <div class="cards">
          <div class="card amber reveal d1">
            <span class="icon">📍</span>
            <h3>Pincode lookup</h3>
            <p>Enter any 6-digit Indian postal code and get the district, state, division, region, and all post offices in that pin — in one response.</p>
          </div>
          <div class="card reveal d2">
            <span class="icon">🏦</span>
            <h3>IFSC lookup</h3>
            <p>Find any bank's IFSC code with full branch details — bank name, branch address, city, district, NEFT/RTGS/IMPS support status.</p>
          </div>
          <div class="card amber reveal d3">
            <span class="icon">⚡</span>
            <h3>Instant results</h3>
            <p>Sub-100ms response times. No spinning loaders, no rate-limiting surprises, no timeouts. Your users won't notice the lookup is even happening.</p>
          </div>
          <div class="card reveal d1">
            <span class="icon">🔌</span>
            <h3>REST API</h3>
            <p>Clean JSON endpoints for Pincode and IFSC lookups. OpenAPI docs included. Authentication via API key — one line to integrate.</p>
          </div>
          <div class="card amber reveal d2">
            <span class="icon">📦</span>
            <h3>Batch processing</h3>
            <p>Send up to 500 codes in a single request. Perfect for validating shipping addresses at import time or enriching existing datasets.</p>
          </div>
          <div class="card reveal d3">
            <span class="icon">🔍</span>
            <h3>Reverse lookup</h3>
            <p>Search by city name, bank name, or district to get all matching pincodes or IFSC codes — useful for search-as-you-type address forms.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Use Cases ── -->
    <section id="use-cases">
      <div class="wrap">
        <p class="kicker reveal" style="color:var(--amber)">Who uses it</p>
        <h2 class="reveal">Built for the teams<br>that run India's internet.</h2>
        <p class="section-intro reveal">
          From D2C startups to enterprise fintech — CodeFinderHub handles the postal and banking data layer so you don't have to.
        </p>
        <div class="cards" style="margin-top:44px">
          <div class="card reveal d1">
            <span class="icon" style="background:var(--amber-soft);font-size:28px">🛒</span>
            <h3>E-commerce &amp; D2C</h3>
            <p>Validate delivery pincodes at checkout. Auto-fill city and state from a 6-digit code. Cut COD failures with real-time serviceability checks.</p>
          </div>
          <div class="card amber reveal d2">
            <span class="icon">🏛️</span>
            <h3>Fintech &amp; BFSI</h3>
            <p>Verify IFSC codes before initiating NEFT/RTGS transfers. Validate bank branch details for KYC flows. Enrich account data with branch addresses.</p>
          </div>
          <div class="card reveal d3">
            <span class="icon" style="background:var(--amber-soft);font-size:28px">👨‍💻</span>
            <h3>Developers &amp; SaaS</h3>
            <p>Drop our REST API into any stack in minutes. Use in address autocomplete, onboarding forms, loan applications, or logistics dashboards.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section style="padding:40px 0 84px">
      <div class="wrap">
        <div class="cta-band reveal" style="background:linear-gradient(135deg, #92400e 0%, #451a03 100%)">
          <h2>Start looking up codes for free.</h2>
          <p>
            No sign-up required to try the web UI. API access takes under 5 minutes to set up.
            Free tier included — no credit card.
          </p>
          <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
            <a class="btn" style="background:#fff;color:#92400e;font-weight:800" href="https://codefinderhub.com" target="_blank" rel="noopener">
              Try it free →
            </a>
            <a class="btn" style="background:rgba(255,255,255,0.12);color:#fff;border:1.5px solid rgba(255,255,255,0.3)" href="https://codefinderhub.com/api" target="_blank" rel="noopener">
              View API docs
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Contact ── -->
    <section class="section-alt" style="padding-top:0">
      <div class="wrap" style="padding-top:64px">
        <p class="kicker reveal" style="color:var(--amber)">Questions?</p>
        <h2 class="reveal">We're happy to help.</h2>
        <p class="section-intro reveal">
          Need a higher rate limit, a custom data export, or enterprise SLA? Reach out directly.
        </p>
        <div class="contact-grid">
          <div class="contact-card reveal d1">
            <span class="icon">📧</span>
            <h3>General enquiries</h3>
            <p>Questions about the API, pricing, or integration? We respond within 1–2 business days.</p>
            <a class="btn btn-amber" href="mailto:satish.technology9@gmail.com">satish.technology9@gmail.com</a>
          </div>
          <div class="contact-card reveal d2">
            <span class="icon">🐛</span>
            <h3>Report an issue</h3>
            <p>Found a code that returns wrong data? Tell us the code and what's incorrect — we'll fix it.</p>
            <a class="btn btn-ghost" style="border-color:var(--amber);color:var(--amber)" href="mailto:satish.technology9@gmail.com?subject=CodeFinderHub%20Data%20Issue">Report an issue →</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer brand="codefinderhub" />
</BaseLayout>
