---
interface Props {
  title?: string;
}
const { title = 'MyStackMint — Home Lab' } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Sathish Kusuma's self-hosted home lab platform" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
    rel="stylesheet"
  />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>

<body class="bg-bg text-white min-h-screen font-sans antialiased overflow-x-hidden">

  <!-- Animated grid background -->
  <div class="fixed inset-0 -z-10 circuit-bg" aria-hidden="true"></div>

  <!-- Radial glow at top -->
  <div
    class="fixed top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full
           bg-mint/5 blur-[120px] -z-10 pointer-events-none"
    aria-hidden="true"
  ></div>

  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';

  .circuit-bg {
    background-color: #0a0a0f;
    background-image:
      linear-gradient(rgba(0, 229, 160, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 229, 160, 0.04) 1px, transparent 1px),
      radial-gradient(circle at 1px 1px, rgba(0, 229, 160, 0.12) 1px, transparent 0);
    background-size: 60px 60px, 60px 60px, 60px 60px;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes cardGlow {
    0%, 100% { box-shadow: 0 0 40px rgba(0, 229, 160, 0.06), 0 24px 60px rgba(0,0,0,0.5); }
    50%       { box-shadow: 0 0 60px rgba(0, 229, 160, 0.12), 0 24px 60px rgba(0,0,0,0.5); }
  }

  .animate-fade-in-up { animation: fadeInUp 0.7s ease both; }
  .animate-fade-in    { animation: fadeIn  0.5s ease both; }
  .delay-100 { animation-delay: 0.1s; }
  .delay-200 { animation-delay: 0.2s; }
  .delay-300 { animation-delay: 0.3s; }
  .delay-400 { animation-delay: 0.4s; }
</style>
