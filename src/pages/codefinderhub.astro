---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';

const title = "CodeFinderHub — India's Pincode & IFSC Lookup";
const description = "Free web tool to look up Indian Pincodes, IFSC codes, and bank branches instantly. No sign-up needed — search postal codes, find branch details, and verify banking information.";
const canonicalUrl = 'https://thestackmint.com/codefinderhub';
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage="/og-codefinderhub.png"
>
  <Header brand="codefinderhub" backLink="/" />

  <main>

    <!-- ── Hero ── -->
    <section class="hero" style="padding-bottom:80px">
      <div class="wrap hero-grid">
        <div>
          <span class="eyebrow reveal in" style="background:var(--amber-soft);color:var(--amber)">
            Free · No sign-up · India-wide coverage
          </span>
          <h1 class="reveal in d1" style="color:var(--ink)">
            India's Pincode &amp; IFSC lookup, <span style="color:var(--amber);font-style:italic">made simple.</span>
          </h1>
          <p class="lede reveal in d2">
            Three tools in one place — search any Indian Pincode, find IFSC codes with full branch details,
            or browse bank branches by name or location. Free to use, no account needed.
          </p>
          <div class="hero-ctas reveal in d3">
            <a class="btn btn-amber" href="https://codefinderhub.com" target="_blank" rel="noopener">Check it now →</a>
            <a class="btn btn-ghost" style="border-color:var(--amber);color:var(--amber)" href="#tools">See the tools</a>
          </div>
        </div>
        <div class="reveal in d2" style="display:flex;align-items:center;justify-content:center">
          <div style="background:linear-gradient(145deg,#92400e,#78350f);border-radius:28px;padding:28px;box-shadow:0 40px 80px rgba(120,53,15,0.35)">
            <div style="background:var(--cream);border-radius:18px;padding:20px;min-width:260px">
              <div style="font-family:var(--font-display);font-weight:700;font-size:0.95rem;margin-bottom:14px;color:var(--ink)">
                🔍 Quick lookup
              </div>
              <div style="background:#fff;border:1.5px solid var(--amber);border-radius:10px;padding:12px 14px;font-size:0.9rem;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center">
                <span style="color:var(--ink-soft)">600001</span>
                <span style="background:var(--amber);color:#fff;border-radius:6px;padding:3px 10px;font-size:0.72rem;font-weight:700">FOUND</span>
              </div>
              <div style="background:#fff;border:1px solid var(--line);border-radius:10px;padding:14px;font-size:0.85rem;margin-bottom:8px">
                <div style="font-weight:700;font-family:var(--font-display);margin-bottom:6px">📍 Chennai GPO</div>
                <div style="color:var(--ink-soft);font-size:0.8rem">Tamil Nadu · Chennai District</div>
                <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap">
                  <span style="background:var(--amber-soft);color:var(--amber);font-size:0.7rem;font-weight:700;padding:2px 8px;border-radius:5px">PINCODE</span>
                  <span style="background:var(--green-soft);color:var(--green);font-size:0.7rem;font-weight:700;padding:2px 8px;border-radius:5px">Post Offices</span>
                </div>
              </div>
              <div style="background:#fff;border:1px solid var(--line);border-radius:10px;padding:14px;font-size:0.85rem">
                <div style="font-weight:700;font-family:var(--font-display);margin-bottom:6px">🏦 SBIN0000300</div>
                <div style="color:var(--ink-soft);font-size:0.8rem">State Bank of India · Fort Branch</div>
                <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap">
                  <span style="background:var(--amber-soft);color:var(--amber);font-size:0.7rem;font-weight:700;padding:2px 8px;border-radius:5px">IFSC</span>
                  <span style="background:var(--green-soft);color:var(--green);font-size:0.7rem;font-weight:700;padding:2px 8px;border-radius:5px">Branch details</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Tools ── -->
    <section id="tools" class="section-alt">
      <div class="wrap">
        <p class="kicker reveal" style="color:var(--amber)">Three tools, one place</p>
        <h2 class="reveal">Everything you need to look up<br>Indian postal &amp; banking codes.</h2>
        <p class="section-intro reveal">
          Whether you're verifying a delivery address, confirming a bank branch before a transfer,
          or browsing branches across a city — it's all here, free, no account needed.
        </p>
        <div class="cards">
          <div class="card amber reveal d1">
            <span class="icon">📍</span>
            <h3>Pincode search</h3>
            <p>Enter any 6-digit Indian postal code to instantly find the matching area names, district, state, and region. Great for verifying addresses or confirming if a pincode is valid.</p>
            <a class="btn btn-amber" style="margin-top:auto;display:inline-block" href="https://codefinderhub.com/pincode?country=IN" target="_blank" rel="noopener">Check it now →</a>
          </div>
          <div class="card reveal d2">
            <span class="icon">🏦</span>
            <h3>IFSC lookup</h3>
            <p>Search by IFSC code or bank/branch name to get complete branch metadata — bank name, branch address, city, district, and supported payment channels (NEFT, RTGS, IMPS).</p>
            <a class="btn btn-ghost" style="margin-top:auto;display:inline-block;border-color:var(--amber);color:var(--amber)" href="https://codefinderhub.com/ifsc?country=IN" target="_blank" rel="noopener">Check it now →</a>
          </div>
          <div class="card amber reveal d3">
            <span class="icon">🗺️</span>
            <h3>Bank branches</h3>
            <p>Filter by Bank → State → City using cascading dropdowns to browse branches of 500+ Indian banks. Click any result to get the full IFSC and branch details.</p>
            <a class="btn btn-amber" style="margin-top:auto;display:inline-block" href="https://codefinderhub.com/branches?country=IN" target="_blank" rel="noopener">Check it now →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Why ── -->
    <section id="why">
      <div class="wrap">
        <p class="kicker reveal" style="color:var(--amber)">Why CodeFinderHub</p>
        <h2 class="reveal">No clutter. No sign-up.<br>Just the answer you need.</h2>
        <p class="section-intro reveal">
          Most Pincode and IFSC lookup sites are ad-heavy, slow, or require an account.
          CodeFinderHub is built to be clean, fast, and always free.
        </p>
        <div class="cards" style="margin-top:44px">
          <div class="card reveal d1">
            <span class="icon">⚡</span>
            <h3>Results in seconds</h3>
            <p>Type a pincode or IFSC and get your answer right away. No waiting, no unnecessary steps — search and done.</p>
          </div>
          <div class="card amber reveal d2">
            <span class="icon">🆓</span>
            <h3>Completely free</h3>
            <p>No account, no subscription, no hidden charges. Open the site and start searching immediately.</p>
          </div>
          <div class="card reveal d3">
            <span class="icon">🇮🇳</span>
            <h3>500+ banks, all pincodes</h3>
            <p>Covers every Indian pincode and 500+ banks with thousands of branches — from SBI and HDFC to co-operative banks and NBFCs.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section style="padding:40px 0 84px">
      <div class="wrap">
        <div class="cta-band reveal" style="background:linear-gradient(135deg, #92400e 0%, #451a03 100%)">
          <h2>Start looking up codes right now.</h2>
          <p>
            No sign-up. No account. Just open the site and search — Pincodes, IFSC codes, and bank branches all in one place.
          </p>
          <a class="btn" style="background:#fff;color:#92400e;font-weight:800" href="https://codefinderhub.com" target="_blank" rel="noopener">
            Check it now →
          </a>
        </div>
      </div>
    </section>

    <!-- ── Contact ── -->
    <section class="section-alt" style="padding-top:0">
      <div class="wrap" style="padding-top:64px">
        <p class="kicker reveal" style="color:var(--amber)">Questions?</p>
        <h2 class="reveal">We're happy to help.</h2>
        <p class="section-intro reveal">
          Found wrong data, or have a suggestion to improve the tool? Reach out directly.
        </p>
        <div class="contact-grid">
          <div class="contact-card reveal d1">
            <span class="icon">📧</span>
            <h3>General enquiries</h3>
            <p>Questions, feedback, or suggestions? We respond within 1–2 business days.</p>
            <a class="btn btn-amber" href="mailto:satish.technology9@gmail.com">satish.technology9@gmail.com</a>
          </div>
          <div class="contact-card reveal d2">
            <span class="icon">🐛</span>
            <h3>Report wrong data</h3>
            <p>Found a Pincode or IFSC that returns incorrect information? Let us know and we'll fix it.</p>
            <a class="btn btn-ghost" style="border-color:var(--amber);color:var(--amber)" href="mailto:satish.technology9@gmail.com?subject=CodeFinderHub%20Data%20Issue">Report an issue →</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer brand="codefinderhub" />
</BaseLayout>
