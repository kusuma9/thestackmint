# Hermes Workspace — copy to .env and fill in values

# Required: session password for remote access (on top of Authelia)
HERMES_PASSWORD=change-me-to-something-strong

# Required: API auth token — shared between agent and workspace
API_SERVER_KEY=change-me-to-a-random-secret

# LLM provider — uncomment ONE and fill in your key:
#ANTHROPIC_API_KEY=sk-ant-...
#OPENAI_API_KEY=sk-...
#OPENROUTER_API_KEY=sk-or-...
#GOOGLE_API_KEY=...
