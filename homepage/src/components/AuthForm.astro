---
// Auth form — visual login/register UI
// Actual authentication is handled by Authelia (Nginx forward auth).
// "Sign In" redirects the user to auth.mystackmint.com which then redirects back to /dashboard.
---

<div class="auth-card w-full max-w-md animate-fade-in-up delay-300">

  <!-- Tab switcher -->
  <div class="flex border-b border-border/60 mb-6" role="tablist">
    <button
      id="tab-login"
      role="tab"
      aria-selected="true"
      aria-controls="panel-login"
      class="tab-btn active flex-1 py-3 text-sm font-semibold text-white border-b-2 border-mint
             transition-all duration-150 focus-visible:outline-mint focus-visible:outline-2"
    >
      Sign In
    </button>
    <button
      id="tab-register"
      role="tab"
      aria-selected="false"
      aria-controls="panel-register"
      class="tab-btn flex-1 py-3 text-sm font-semibold text-muted border-b-2 border-transparent
             hover:text-white transition-all duration-150 focus-visible:outline-mint focus-visible:outline-2"
    >
      Register
    </button>
  </div>

  <!-- Login panel -->
  <div id="panel-login" role="tabpanel" aria-labelledby="tab-login">
    <form id="login-form" class="flex flex-col gap-4" novalidate>

      <div class="flex flex-col gap-1.5">
        <label for="login-email" class="text-xs font-mono text-muted uppercase tracking-widest">
          Email address
        </label>
        <input
          id="login-email"
          type="email"
          autocomplete="email"
          placeholder="you@example.com"
          class="w-full bg-surface2 border border-border rounded-lg px-4 py-3 text-sm text-white
                 placeholder:text-muted/50 focus:outline-none focus:border-mint/60 focus:ring-1
                 focus:ring-mint/20 transition-all duration-150"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <div class="flex items-center justify-between">
          <label for="login-password" class="text-xs font-mono text-muted uppercase tracking-widest">
            Password
          </label>
          <a
            href="https://auth.mystackmint.com/reset-password"
            class="text-xs text-muted hover:text-mint transition-colors"
          >
            Forgot password?
          </a>
        </div>
        <input
          id="login-password"
          type="password"
          autocomplete="current-password"
          placeholder="••••••••••••"
          class="w-full bg-surface2 border border-border rounded-lg px-4 py-3 text-sm text-white
                 placeholder:text-muted/50 focus:outline-none focus:border-mint/60 focus:ring-1
                 focus:ring-mint/20 transition-all duration-150"
        />
      </div>

      <button
        type="submit"
        class="w-full mt-1 py-3 rounded-lg bg-mint text-bg font-bold text-sm tracking-wide
               hover:bg-mint-dark active:scale-[0.98] transition-all duration-150
               focus-visible:outline-mint focus-visible:outline-2 focus-visible:outline-offset-2"
      >
        Sign In
      </button>

    </form>

    <p class="mt-5 text-center text-xs text-muted/60">
      Protected by
      <a href="https://auth.mystackmint.com" class="text-mint/70 hover:text-mint transition-colors">
        Authelia SSO
      </a>
    </p>
  </div>

  <!-- Register panel -->
  <div id="panel-register" role="tabpanel" aria-labelledby="tab-register" class="hidden">
    <div class="flex flex-col gap-4">

      <div class="flex flex-col gap-1.5">
        <label for="reg-name" class="text-xs font-mono text-muted uppercase tracking-widest">
          Full name
        </label>
        <input
          id="reg-name"
          type="text"
          autocomplete="name"
          placeholder="Sathish Kusuma"
          class="w-full bg-surface2 border border-border rounded-lg px-4 py-3 text-sm text-white
                 placeholder:text-muted/50 focus:outline-none focus:border-cyan/60 focus:ring-1
                 focus:ring-cyan/20 transition-all duration-150"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="reg-email" class="text-xs font-mono text-muted uppercase tracking-widest">
          Email address
        </label>
        <input
          id="reg-email"
          type="email"
          autocomplete="email"
          placeholder="you@example.com"
          class="w-full bg-surface2 border border-border rounded-lg px-4 py-3 text-sm text-white
                 placeholder:text-muted/50 focus:outline-none focus:border-cyan/60 focus:ring-1
                 focus:ring-cyan/20 transition-all duration-150"
        />
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div class="flex flex-col gap-1.5">
          <label for="reg-password" class="text-xs font-mono text-muted uppercase tracking-widest">
            Password
          </label>
          <input
            id="reg-password"
            type="password"
            autocomplete="new-password"
            placeholder="••••••••"
            class="w-full bg-surface2 border border-border rounded-lg px-4 py-3 text-sm text-white
                   placeholder:text-muted/50 focus:outline-none focus:border-cyan/60 focus:ring-1
                   focus:ring-cyan/20 transition-all duration-150"
          />
        </div>
        <div class="flex flex-col gap-1.5">
          <label for="reg-confirm" class="text-xs font-mono text-muted uppercase tracking-widest">
            Confirm
          </label>
          <input
            id="reg-confirm"
            type="password"
            autocomplete="new-password"
            placeholder="••••••••"
            class="w-full bg-surface2 border border-border rounded-lg px-4 py-3 text-sm text-white
                   placeholder:text-muted/50 focus:outline-none focus:border-cyan/60 focus:ring-1
                   focus:ring-cyan/20 transition-all duration-150"
          />
        </div>
      </div>

      <!-- Admin approval notice -->
      <div class="flex gap-2.5 bg-cyan/5 border border-cyan/15 rounded-lg px-4 py-3 mt-1">
        <svg class="w-4 h-4 text-cyan flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-xs text-cyan/80 leading-relaxed">
          Account creation requires <strong class="text-cyan">admin approval</strong>.
          Send your request to
          <a href="mailto:satish.technology9@gmail.com"
             class="underline underline-offset-2 hover:text-white transition-colors">
            satish.technology9@gmail.com
          </a>
        </p>
      </div>

      <button
        type="button"
        disabled
        class="w-full mt-1 py-3 rounded-lg bg-surface2 border border-border text-muted font-bold
               text-sm tracking-wide cursor-not-allowed opacity-60"
      >
        Request Access
      </button>
    </div>
  </div>

</div>

<script>
  // Tab switching
  const tabLogin    = document.getElementById('tab-login')!;
  const tabRegister = document.getElementById('tab-register')!;
  const panelLogin  = document.getElementById('panel-login')!;
  const panelReg    = document.getElementById('panel-register')!;

  function activateTab(tab: 'login' | 'register') {
    const isLogin = tab === 'login';

    tabLogin.setAttribute('aria-selected', String(isLogin));
    tabRegister.setAttribute('aria-selected', String(!isLogin));

    tabLogin.classList.toggle('text-white',   isLogin);
    tabLogin.classList.toggle('border-mint',  isLogin);
    tabLogin.classList.toggle('text-muted',  !isLogin);
    tabLogin.classList.toggle('border-transparent', !isLogin);

    tabRegister.classList.toggle('text-white',  !isLogin);
    tabRegister.classList.toggle('border-cyan', !isLogin);
    tabRegister.classList.toggle('text-muted',   isLogin);
    tabRegister.classList.toggle('border-transparent', isLogin);

    panelLogin.classList.toggle('hidden',  !isLogin);
    panelReg.classList.toggle('hidden',    isLogin);
  }

  tabLogin.addEventListener('click',    () => activateTab('login'));
  tabRegister.addEventListener('click', () => activateTab('register'));

  // Login form — redirect to Authelia
  document.getElementById('login-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const rd = encodeURIComponent('https://mystackmint.com/dashboard/');
    window.location.href = `https://auth.mystackmint.com/?rd=${rd}`;
  });
</script>
