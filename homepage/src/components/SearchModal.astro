---
import { tools } from '../tools.config';
---

<!-- CMD+K search overlay -->
<div
  id="search-modal"
  class="fixed inset-0 z-50 flex items-start justify-center pt-[15vh] px-4 hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Search tools"
>
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>

  <!-- Modal panel -->
  <div class="relative w-full max-w-xl bg-surface border border-border rounded-2xl shadow-2xl
              shadow-black/50 overflow-hidden">

    <!-- Search input -->
    <div class="flex items-center gap-3 px-4 border-b border-border">
      <svg class="w-5 h-5 text-muted flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="Search tools..."
        class="flex-1 bg-transparent py-4 text-sm text-white placeholder:text-muted
               focus:outline-none"
        autocomplete="off"
        spellcheck="false"
      />
      <kbd class="hidden sm:flex items-center gap-1 text-[10px] font-mono text-muted/60
                  bg-surface2 border border-border px-1.5 py-0.5 rounded">
        ESC
      </kbd>
    </div>

    <!-- Results list -->
    <ul id="search-results" class="max-h-80 overflow-y-auto py-2" role="listbox"></ul>

    <!-- Empty state -->
    <div id="search-empty" class="hidden py-8 text-center text-sm text-muted">
      No tools found
    </div>

    <!-- Footer hint -->
    <div class="flex items-center gap-4 px-4 py-2.5 border-t border-border text-[10px] font-mono text-muted/60">
      <span><kbd class="bg-surface2 border border-border px-1.5 py-0.5 rounded">↑↓</kbd> navigate</span>
      <span><kbd class="bg-surface2 border border-border px-1.5 py-0.5 rounded">↵</kbd> open</span>
      <span><kbd class="bg-surface2 border border-border px-1.5 py-0.5 rounded">ESC</kbd> close</span>
    </div>
  </div>
</div>

<!-- Tool data for client-side search -->
<script type="application/json" id="tools-data">
  {JSON.stringify(tools)}
</script>
