---
import DashLayout from '../../layouts/DashLayout.astro';
---

<DashLayout title="Dashboard — MyStackMint">

  <main class="min-h-[calc(100vh-3.5rem)] flex flex-col items-center justify-center px-4 py-12">

    <!-- Greeting -->
    <div class="text-center mb-12">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">
        Good to have you back
      </h1>
      <p class="text-muted text-sm">
        Where would you like to go?
      </p>
    </div>

    <!-- Path cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 w-full max-w-3xl">

      <!-- Personal HomeLab -->
      <a
        href="/homelab"
        class="group relative flex flex-col gap-5 p-8 rounded-2xl border border-border bg-surface
               overflow-hidden transition-all duration-300
               hover:border-mint/40 hover:-translate-y-1
               hover:shadow-[0_8px_48px_rgba(0,229,160,0.14)]
               focus-visible:outline-mint focus-visible:outline-2"
      >
        <!-- Background glow -->
        <div
          class="absolute inset-0 bg-gradient-to-br from-mint/5 via-transparent to-transparent
                 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
          aria-hidden="true"
        ></div>

        <!-- Icon -->
        <div class="relative w-14 h-14 rounded-xl bg-mint/10 border border-mint/20
                    flex items-center justify-center text-2xl
                    group-hover:bg-mint/15 group-hover:border-mint/40 transition-all duration-300">
          🏠
        </div>

        <!-- Text -->
        <div class="relative flex flex-col gap-2 flex-1">
          <h2 class="text-xl font-bold text-white group-hover:text-mint transition-colors duration-200">
            Personal HomeLab
          </h2>
          <p class="text-muted text-sm leading-relaxed">
            Family tools, media streaming, files, documents, and productivity apps.
          </p>
        </div>

        <!-- Arrow -->
        <div class="relative flex items-center gap-2 text-mint/60 text-sm font-mono
                    group-hover:text-mint group-hover:gap-3 transition-all duration-200">
          Enter
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </div>

        <!-- Corner tag -->
        <div class="absolute top-4 right-4 flex gap-1">
          <span class="text-[9px] font-mono uppercase tracking-widest text-mint/40 bg-mint/5
                       border border-mint/10 px-1.5 py-0.5 rounded-full">
            15 apps
          </span>
        </div>
      </a>

      <!-- SaaS Products -->
      <a
        href="/saas"
        class="group relative flex flex-col gap-5 p-8 rounded-2xl border border-border bg-surface
               overflow-hidden transition-all duration-300
               hover:border-cyan/40 hover:-translate-y-1
               hover:shadow-[0_8px_48px_rgba(0,196,255,0.14)]
               focus-visible:outline-2 focus-visible:outline-cyan"
      >
        <!-- Background glow -->
        <div
          class="absolute inset-0 bg-gradient-to-br from-cyan/5 via-transparent to-transparent
                 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
          aria-hidden="true"
        ></div>

        <!-- Icon -->
        <div class="relative w-14 h-14 rounded-xl bg-cyan/10 border border-cyan/20
                    flex items-center justify-center text-2xl
                    group-hover:bg-cyan/15 group-hover:border-cyan/40 transition-all duration-300">
          🚀
        </div>

        <!-- Text -->
        <div class="relative flex flex-col gap-2 flex-1">
          <h2 class="text-xl font-bold text-white group-hover:text-cyan transition-colors duration-200">
            SaaS Products
          </h2>
          <p class="text-muted text-sm leading-relaxed">
            Hosted SaaS applications, analytics, monitoring, and infrastructure tools.
          </p>
        </div>

        <!-- Arrow -->
        <div class="relative flex items-center gap-2 text-cyan/60 text-sm font-mono
                    group-hover:text-cyan group-hover:gap-3 transition-all duration-200">
          Enter
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </div>

        <!-- Corner tag -->
        <div class="absolute top-4 right-4 flex gap-1">
          <span class="text-[9px] font-mono uppercase tracking-widest text-cyan/40 bg-cyan/5
                       border border-cyan/10 px-1.5 py-0.5 rounded-full">
            6 apps
          </span>
        </div>
      </a>

    </div>

    <!-- Quick status link -->
    <div class="mt-10 text-center">
      <a
        href="https://status.mystackmint.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-xs font-mono text-muted/50 hover:text-muted
               transition-colors duration-150"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-mint animate-pulse"></span>
        System Status
      </a>
    </div>

  </main>

</DashLayout>
