---
import AuthLayout from '../layouts/AuthLayout.astro';
import AuthForm from '../components/AuthForm.astro';
---

<AuthLayout title="MyStackMint — Home Lab">

  <div class="min-h-screen flex flex-col items-center justify-center px-4 py-16">

    <!-- Hero -->
    <div class="text-center mb-10 animate-fade-in-up">

      <!-- Wordmark -->
      <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full
                  bg-mint/5 border border-mint/15 text-[11px] font-mono text-mint/80 tracking-widest uppercase">
        <span class="w-1.5 h-1.5 rounded-full bg-mint animate-pulse"></span>
        mystackmint.com
      </div>

      <!-- Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-tight mb-4 text-white">
        Welcome to<br />
        <span class="bg-gradient-to-r from-white via-mint to-cyan bg-clip-text text-transparent">
          Sathish Kusuma's
        </span><br />
        <span class="text-white/90">Home Lab</span>
      </h1>

      <!-- Subtext -->
      <p class="text-muted text-base sm:text-lg max-w-md mx-auto leading-relaxed animate-fade-in-up delay-100">
        A self-hosted platform for personal tools<br class="hidden sm:block" />
        and SaaS experiments.
      </p>
    </div>

    <!-- Auth card -->
    <div class="w-full max-w-md animate-fade-in-up delay-200">
      <div class="glass-card rounded-2xl p-8">
        <AuthForm />
      </div>
    </div>

    <!-- Footer -->
    <p class="mt-10 text-xs font-mono text-muted/40 animate-fade-in delay-400">
      Powered by
      <a href="https://coolify.io" target="_blank" rel="noopener"
         class="hover:text-muted/70 transition-colors">Coolify</a>
      &nbsp;·&nbsp;
      Secured by
      <a href="https://www.authelia.com" target="_blank" rel="noopener"
         class="hover:text-muted/70 transition-colors">Authelia</a>
    </p>

  </div>

</AuthLayout>

<style>
  .glass-card {
    background: rgba(18, 18, 26, 0.85);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(42, 42, 61, 0.8);
    box-shadow:
      0 0 0 1px rgba(0, 229, 160, 0.04),
      0 0 60px rgba(0, 229, 160, 0.06),
      0 32px 80px rgba(0, 0, 0, 0.6);
    animation: cardGlow 4s ease infinite;
  }
</style>
