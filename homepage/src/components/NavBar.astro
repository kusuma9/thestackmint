---
const pathname = Astro.url.pathname;
const isHomelab = pathname.startsWith('/homelab');
const isSaas = pathname.startsWith('/saas');
const isAiAgents = pathname.startsWith('/ai-agents');
---

<header class="sticky top-0 z-30 border-b border-border/50 bg-bg/90 backdrop-blur-xl">
  <nav class="max-w-7xl mx-auto flex items-center justify-between px-4 lg:px-8 h-14">

    <!-- Logo -->
    <a href="/dashboard" class="flex items-center gap-2 group" aria-label="Back to dashboard">
      <span class="font-mono text-[10px] text-muted uppercase tracking-widest group-hover:text-mint/70 transition-colors">
        mystackmint
      </span>
      <span class="text-white font-bold text-base leading-none group-hover:text-mint transition-colors">
        My<span class="text-mint">Stack</span>Mint
      </span>
    </a>

    <!-- Center nav -->
    <div class="flex items-center gap-1">
      <a
        href="/homelab"
        class:list={[
          'flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-all duration-150',
          isHomelab
            ? 'text-mint bg-mint/10 border border-mint/20'
            : 'text-muted hover:text-white hover:bg-surface2',
        ]}
      >
        <span aria-hidden="true">🏠</span>
        Personal HomeLab
      </a>
      <a
        href="/saas"
        class:list={[
          'flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-all duration-150',
          isSaas
            ? 'text-cyan bg-cyan/10 border border-cyan/20'
            : 'text-muted hover:text-white hover:bg-surface2',
        ]}
      >
        <span aria-hidden="true">🚀</span>
        SaaS Products
      </a>
      <a
        href="/ai-agents"
        class:list={[
          'flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-all duration-150',
          isAiAgents
            ? 'text-purple bg-purple/10 border border-purple/20'
            : 'text-muted hover:text-white hover:bg-surface2',
        ]}
      >
        <span aria-hidden="true">🤖</span>
        AI Agents
      </a>
    </div>

    <!-- Logout -->
    <a
      href="https://auth.mystackmint.com/logout?rd=https%3A%2F%2Fmystackmint.com%2F"
      class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-mono text-muted
             hover:text-white hover:bg-surface2 border border-transparent hover:border-border/50
             transition-all duration-150"
    >
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
      Logout
    </a>
  </nav>
</header>
