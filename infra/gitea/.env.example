DB_PASSWORD=replace_with_strong_password
WP_DB_PASSWORD=replace_with_strong_password
# Generate: openssl rand -hex 32
GITEA_SECRET_KEY=replace_with_64_char_hex_string

# Woodpecker OAuth app — create in Gitea: Settings → Applications → OAuth2
WOODPECKER_GITEA_CLIENT=your_gitea_oauth_client_id
WOODPECKER_GITEA_SECRET=your_gitea_oauth_client_secret

# Generate: openssl rand -hex 32
WOODPECKER_AGENT_SECRET=replace_with_64_char_hex_string
