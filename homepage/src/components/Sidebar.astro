---
import { CATEGORIES, type ToolCategory } from '../tools.config';

interface Props {
  categories?: ToolCategory[];
  withNavbar?: boolean;
}
const { categories = CATEGORIES, withNavbar = false } = Astro.props;

const icons: Record<string, string> = {
  'Files & Storage': '📂',
  'Photos & Media': '🎬',
  'Security & Auth': '🛡️',
  'Productivity': '✅',
  'Finance & Home': '🏡',
  'DevOps & SaaS': '🚀',
  'AI Agents': '🤖',
  'Products': '📦',
};
---

<aside
  id="sidebar"
  class:list={[
    'fixed left-0 h-full w-56 bg-surface border-r border-border z-20',
    'flex flex-col py-6 gap-1',
    '-translate-x-full lg:translate-x-0 transition-transform duration-200',
    withNavbar ? 'top-14' : 'top-0',
  ]}
  aria-label="Category navigation"
>
  <!-- Logo -->
  <div class="px-5 mb-5">
    <span class="font-mono text-xs text-muted uppercase tracking-widest">mystackmint</span>
    <h1 class="text-white font-bold text-lg leading-tight mt-0.5">
      My<span class="text-mint">Stack</span>Mint
    </h1>
  </div>

  <!-- All tools -->
  <button
    class="sidebar-btn active flex items-center gap-3 px-5 py-2.5 text-sm font-medium rounded-r-xl mr-3
           text-white bg-mint/10 border-r-2 border-mint transition-all duration-150
           hover:bg-mint/15 focus-visible:outline-mint focus-visible:outline-2"
    data-category="all"
    aria-pressed="true"
  >
    <span class="text-base" aria-hidden="true">🏠</span>
    All Tools
  </button>

  <!-- Category buttons -->
  {categories.map((cat) => (
      <button
        class="sidebar-btn flex items-center gap-3 px-5 py-2.5 text-sm font-medium rounded-r-xl mr-3
               text-muted hover:text-white hover:bg-surface2 border-r-2 border-transparent
               transition-all duration-150 focus-visible:outline-mint focus-visible:outline-2"
        data-category={cat}
        aria-pressed="false"
      >
        <span class="text-base" aria-hidden="true">{icons[cat] ?? '📦'}</span>
        {cat}
      </button>
  ))}

  <!-- Bottom: theme toggle -->
  <div class="mt-auto px-5">
    <button
      id="theme-toggle"
      class="flex items-center gap-2 text-xs text-muted hover:text-white transition-colors py-2
             focus-visible:outline-mint focus-visible:outline-2 rounded"
      aria-label="Toggle theme"
    >
      <span id="theme-icon">🌙</span>
      <span id="theme-label">Dark mode</span>
    </button>
  </div>
</aside>

<!-- Mobile overlay -->
<button
  id="sidebar-overlay"
  class="fixed inset-0 bg-black/60 z-10 hidden lg:hidden"
  aria-label="Close menu"
></button>
